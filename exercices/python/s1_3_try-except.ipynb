    "## 3\n",
    "produit = {\"nom\": \"Clavier\", \"prix\": 89.9}\n",
    "\n",
    "try:\n",
    "    stock = produit[\"stock\"]\n",
    "except KeyError as k:\n",
    "    print(\"Erreur : stock non renseigné\")\n",
    "else:\n",
    "    print(\"Le stock est parfaitement renseigné et le voici : \", stock)"
