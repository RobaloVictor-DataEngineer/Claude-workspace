   "source": [
    "## 1\n",
    "def division(a, b):\n",
    "    try:\n",
    "        d = a/b\n",
    "    except ZeroDivisionError as z:\n",
    "        print (\"Division par zéro impossible\")\n",
    "    else: \n",
    "        print(\"La division est réussi et votre résultat est :\")\n",
    "        return d\n",
    "\n",
    "print(division(10, 2),\"\\n\")\n",
    "print(division(10, 0))\n",
    "\n"
   ]
  },
