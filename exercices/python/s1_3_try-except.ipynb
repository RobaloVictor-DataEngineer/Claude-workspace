   "source": [
    "## 2\n",
    "def convertir_entier(texte):\n",
    "    try:\n",
    "        a =int(texte)\n",
    "    except ValueError as v:\n",
    "        print (\"Erreur : \", v)\n",
    "    else:\n",
    "        print(\"La conversionn est réussi :\")\n",
    "        return type(a), a \n",
    "    \n",
    "\n",
    "print(convertir_entier(\"8\"),\"\\n\")\n",
    "print(convertir_entier(\"bonjour\"))"
   ]
  },
